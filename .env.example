# ── Telegram Bot credentials ───────────────────────────────────────
# Copy this file to .env.local and fill in real values.
#
# IMPORTANT: Vite inlines every VITE_* variable into the client bundle
# at build time. These values are therefore NOT secret at runtime — they
# are visible to anyone who inspects the shipped JavaScript. Keeping them
# here only removes them from source control / git history. If the token
# leaks or is abused, rotate it in BotFather. For true secrecy, move the
# Telegram call behind a server-side proxy/endpoint.

VITE_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
VITE_TELEGRAM_CHAT_ID=your-telegram-chat-id
